<h2 class="text-center py-2">Employees</h2>
<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th scope="col">#</th>
      <th scope="col">First name</th>
      <th scope="col">Last name</th>
      <th scope="col">Birth</th>
      <th scope="col">Gender</th>
      <th scope="col">Civil ID</th>
      <th scope="col">Phone number</th>
      <th scope="col">Address</th>
      <th scope="col">Department</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% employees.forEach(employee => { %>
    <tr>
      <th><%= employee.id %></th>
      <td><%= employee.first_name %></td>
      <td><%= employee.last_name %></td>
      <td><%= employee.birth %></td>
      <td><%= employee.gender %></td>
      <td><%= employee.civil_id %></td>
      <td><%= employee.phone_number %></td>
      <td><%= employee.address %></td>
      <td><%= employee.Department.name %></td>
      <td>
        <button type="button" class="btn btn-outline-primary my-1">Edit</button>
        <form
          action="/api/employees/<%= employee.id %>?method=DELETE"
          method="post"
        >
          <button type="submit" class="btn btn-outline-danger my-1">
            Delete
          </button>
        </form>
      </td>
    </tr>
    <% }) %>
  </tbody>
</table>
