<!DOCTYPE html>
<html lang="en">
  <%- include("../includes/head.ejs") %>
  <body>
    <%- include("../includes/theme.ejs") %>
    <div class="d-flex align-items-center py-5 bg-body-tertiary">
      <main class="form-signin w-100 m-auto">
        <h2 class="my-2 fw-light text-center">Admin</h2>

        <h4 class="mb-3 fw-normal">Sign in</h4>

        <% if (messages.info) { %>
        <div class="alert alert-primary" role="alert"><%= messages.info %></div>
        <% } %> <% if (messages.error) { %>
        <div class="alert alert-danger" role="alert"><%= messages.error %></div>
        <% } %> <% if (messages.success) { %>
        <div class="alert alert-success" role="alert">
          <%= messages.success %>
        </div>
        <% } %>
        <form action="/api/auth" method="POST">
          <div class="form-floating">
            <input
              type="text"
              class="form-control"
              id="floatingInput"
              placeholder=""
              name="username"
            />
            <label for="floatingInput">Username</label>
          </div>
          <div class="form-floating mt-2">
            <input
              type="password"
              class="form-control"
              id="floatingPassword"
              placeholder=""
              name="password"
            />
            <label for="floatingPassword">Password</label>
          </div>

          <div class="form-check text-start my-3">
            <input
              class="form-check-input"
              type="checkbox"
              value="remember-me"
              id="flexCheckDefault"
            />
            <label class="form-check-label" for="flexCheckDefault">
              Remember me
            </label>
          </div>
          <button class="btn btn-primary w-100 my-1" type="submit">
            Sign in
          </button>
          <p class="my-2 text-body-secondary">
            © <%= new Date().getFullYear() %>
          </p>
        </form>
      </main>
    </div>
    <%- include("../includes/foot.ejs") %>
  </body>
</html>
